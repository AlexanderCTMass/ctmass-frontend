ALLOWED_EVENT_TYPES=firebase.extensions.firestore-send-email.v1.onStart
AUTH_TYPE=UsernamePassword
DATABASE=(default)
DATABASE_REGION=nam5
DEFAULT_FROM=CTMASS Support team <support@ctmass.com>
DEFAULT_REPLY_TO=support@ctmass.com
EVENTARC_CHANNEL=projects/${param:PROJECT_ID}/locations/us-central1/channels/firebase
firebaseextensions.v1beta.function/location=us-east5
MAIL_COLLECTION=mail
OAUTH_PORT=465
OAUTH_SECURE=true
SMTP_CONNECTION_URI=smtps://support@ctmass.com@smtp.gmail.com:465
TEMPLATES_COLLECTION=email_templates
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1
USER=support@gmail.com
USERS_COLLECTION=profiles