{
  "name": "@ctmass/react",
  "version": "6.1.0",
  "author": "AlexNeuro",
  "homepage": "https://ctmass.com",
  "private": true,
  "scripts": {
    "clean": "rimraf build",
    "start": "react-scripts start -- --host 0.0.0.0",
    "build": "cross-env NODE_ENV=development REACT_APP_ENV=development react-scripts build",
    "build:dev": "cross-env NODE_ENV=development REACT_APP_ENV=development react-scripts build",
    "build:prod": "cross-env NODE_ENV=production REACT_APP_ENV=production react-scripts build",
    "deploy:dev": "npm run clean && npm run build:dev && firebase use development && firebase deploy --only hosting",
    "deploy:prod": "npm run clean && npm run build:prod && firebase use production && firebase deploy --only hosting",
    "firebase:deploy only hosting": "firebase use production && firebase deploy --only hosting",
    "firestore:indexes from dev": "firebase firestore:indexes --project ctmasstest > firestore.indexes.dev.json",
    "lint": "eslint ./src",
    "lint-fix": "eslint --fix ./src"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not safari < 10",
      "not chrome < 51",
      "not android < 5",
      "not ie < 12"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
